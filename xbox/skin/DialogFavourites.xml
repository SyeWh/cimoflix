		</control>
		<control type="list" id="450">
			<posx>60</posx>
			<posy>124</posy>
			<width>600</width>
			<height>384</height>
			<onleft>450</onleft>
			<onright>450</onright>
			<onup>450</onup>
			<ondown>450</ondown>
			<itemlayout height="48">
