					<colordiffuse>FFE50914</colordiffuse>
				</control>
				<control type="label">
					<posx>16</posx>
					<posy>0</posy>
					<width>568</width>
					<height>48</height>
					<font>cimoflix26b</font>
					<textcolor>FFFFFFFF</textcolor>
					<aligny>center</aligny>
					<align>left</align>
					<info>ListItem.Label</info>
				</control>
			</focusedlayout>
		</control>
		<control type="label">
			<description>controller hint</description>
			<posx>60</posx>
			<posy>522</posy>
			<width>600</width>
			<height>24</height>
			<font>font101</font>
			<textcolor>FF8A8A92</textcolor>
